# Redirect direnv layouts to $HOME/.cache/direnv/layouts/ to support exfat/NTFS filesystems without symlink support
: ${XDG_CACHE_HOME:=$HOME/.cache}
declare -A direnv_layout_dirs
direnv_layout_dir() {
  echo "${direnv_layout_dirs[$PWD]:=$( echo -n "$XDG_CACHE_HOME"/direnv/layouts/ && echo -n "$PWD" | sha1sum | cut -d ' ' -f 1 )}"
}

use flake
