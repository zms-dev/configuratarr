  "paths": {
    "/healthz/liveness": {
      "get": {
        "operationId": "get_healthz_liveness",
        "summary": "Liveness check",
        "responses": {
          "200": {
            "description": "Application is running"
          }
        }
      }
    },
    "/healthz/readiness": {
      "get": {
        "operationId": "get_healthz_readiness",
        "summary": "Readiness check",
        "responses": {
          "200": {
            "description": "Application and dependencies are ready"
          },
          "500": {
            "description": "One or more dependencies are unavailable"
          }
        }
      }
    },
    "/filters": {
      "get": {
        "operationId": "get_filters",
        "summary": "List all filters",
        "responses": {
          "200": {
            "description": "List of filters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Filter"
                  }
                }
              }
